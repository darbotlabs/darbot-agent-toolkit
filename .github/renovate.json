{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:base"],
  "username": "darbot-renovate[bot]",
  "gitAuthor": "darbot-renovate<darbot-renovate[bot]@users.noreply.github.com>",
  "dependencyDashboard": false,
  "repositories": ["darbotlabs/darbot-agent-toolkit"],
  "includePaths": ["packages/sdk/**", "packages/sdk-react/**", "templates/**"],
  "enabledManagers": ["npm"],
  "npm": {
    "fileMatch": ["(^|/)package\\.json.tpl$"]
  },
  "packageRules": [
    {
      "enabled": false,
      "matchDepPatterns": ["*"],
      "excludeDepNames": [
        "botbuilder",
        "botbuilder-dialogs",
        "botframework-schema",
        "botbuilder-core",
        "@microsoft/teams-js",
        "@microsoft/microsoft-graph-client",
        "@microsoft/mgt-element",
        "@microsoft/mgt-react",
        "@microsoft/mgt-teamsfx-provider"
      ]
    },
    {
      "groupName": "botbuilder",
      "matchPackageNames": [
        "botbuilder",
        "botbuilder-dialogs",
        "botframework-schema",
        "botbuilder-core"
      ]
    },
    {
      "groupName": "graph toolkit",
      "matchPackageNames": [
        "@microsoft/mgt-element",
        "@microsoft/mgt-react",
        "@microsoft/mgt-teamsfx-provider"
      ]
    },
    {
      "matchPackageNames": [
        "botbuilder",
        "botbuilder-dialogs",
        "botframework-schema",
        "botbuilder-core",
        "@microsoft/teams-js",
        "@microsoft/microsoft-graph-client",
        "@microsoft/mgt-element",
        "@microsoft/mgt-react",
        "@microsoft/mgt-teamsfx-provider"
      ],
      "matchPaths": [
        "packages/sdk/package.json",
        "packages/sdk-react/package.json",
        "templates/**/package.json.tpl"
      ],
      "rangeStrategy": "auto"
    }
  ]
}
